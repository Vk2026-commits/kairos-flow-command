# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Google Maps Platform
# Browser key: restrict this key to your production domains and enable Maps JavaScript API + Places API.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Server/static key: used by the app when exporting Static Maps images.
# Enable Static Maps API. You can use GOOGLE_MAPS_API_KEY instead if your host only supports one server key.
GOOGLE_MAPS_STATIC_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional tracking channel for Maps JavaScript API usage reports.
VITE_GOOGLE_MAPS_CHANNEL=
